# ─────────────────────────────────────────────────────────────────────────────
# NeoDoc — Environment Configuration
# Copy this file to .env and fill in the values below.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED — generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_LONG_RANDOM_STRING
JWT_EXPIRES_IN=24h

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/vault.db

# ── OpenAI (optional — enables AI features) ──────────────────────────────────
# Get a key at https://platform.openai.com
# Leave blank to run without AI features.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Watch Folder ─────────────────────────────────────────────────────────────
# Files dropped into this folder are automatically ingested.
WATCH_FOLDER=./inbox
WATCH_ENABLED=false

# ── Backups ──────────────────────────────────────────────────────────────────
# Set BACKUP_PATH to enable automatic backups.
# Each snapshot saves the database + .env to a timestamped sub-folder.
# Leave BACKUP_PATH blank (or remove the line) to disable backups entirely.
# BACKUP_PATH=./backups
# BACKUP_INTERVAL_HOURS=24   # how often to snapshot (default: 24)
# BACKUP_KEEP=10             # number of snapshots to retain (default: 10)

# ── App Defaults (can also be changed in the Settings UI) ────────────────────
APP_NAME=NeoDoc
MAX_FILE_MB=50
ALLOWED_TYPES=application/pdf,image/jpeg,image/png,image/webp,image/gif,text/plain
REGISTRATION_OPEN=true
